# ── COS Glasses Server — configuration ──────────────────────────────────
# Lives at ~/.cos-glasses/.env (created on first run). Everything here is
# OPTIONAL — the server boots and chats with zero config as long as the
# Claude Code CLI is installed and logged in.

# ── PHONE ACCESS ────────────────────────────────────────────────────────
# The glasses app (on your iPhone) reaches this server over your network or
# mesh. The launcher sets 0.0.0.0 for you; set 127.0.0.1 to restrict to the
# local machine only. (The IP allowlist always blocks public internet traffic.)
BIND_HOST=0.0.0.0

# HTTP port the server listens on. HTTPS auto-enables on 3143 if you add
# cert.pem + key.pem under server/certs/ (optional; iOS WebView prefers HTTPS).
# PORT=3141

# ── AUTH ────────────────────────────────────────────────────────────────
# A token is REQUIRED on every /api call. Leave UNSET and the server prints an
# auto-generated one at boot — paste it into the phone app. Set a fixed value
# here for a stable token across restarts.
# COS_API_TOKEN=pick-any-long-random-string

# Optional durable image-store location. Defaults to
# ~/.cos-glasses/data/media alongside the standalone conversation/archive data.
# COS_MEDIA_ROOT=/path/on-a-local-volume/media

# Optional logical server identity location. Most installs should keep the
# default (~/.cos-glasses/server-instance-id) so reconnects can verify the same
# server after Wi-Fi/Tailscale changes and process restarts.
# COS_SERVER_INSTANCE_ID_PATH=/path/to/server-instance-id

# Build 204+ can opt into server-owned durable query jobs. The server fsyncs an
# accepted prompt before returning 202, then keeps provider work running if the
# phone backgrounds, reloads, or changes networks. Reopening COS reattaches to
# the same job. Set to 0 (or remove) to send NEW prompts through the legacy
# streaming route; already accepted durable jobs remain readable/cancellable
# and drain safely.
# COS_DURABLE_QUERY_JOBS=1

# ── THE LLM (chat) ──────────────────────────────────────────────────────
# Chat runs through your LOCAL agent CLI — NOT an API key:
#   Opus / Fable / Sonnet  ->  Claude Code CLI  (https://claude.ai/download, then `claude login`)
#   GPT Frontier/Balanced  ->  Codex CLI        (https://developers.openai.com/codex/, then `codex login`)
# Install at least one. Pick the default model the glasses use:
# COS_G2_DEFAULT_MODEL=sonnet     # opus | fable | sonnet | codex-frontier | codex-balanced
#
# GPT slots refresh from the Codex model catalog every 15 minutes and retain
# their last-known-good resolution if discovery is temporarily unavailable.
# COS_CODEX_MODEL_REFRESH_TTL_MS=900000
# COS_CODEX_MODEL_REFRESH_TIMEOUT_MS=7000
#
# Legacy explicit overrides remain supported for migrated codex-high/frontier
# installs. Leave blank for auto-latest; Balanced always stays auto-catalog.
# COS_CODEX_MODEL=
# COS_CODEX_REASONING_EFFORT=high   # low | medium | high | xhigh | max | ultra
#
# Codex remains read-only by default. This is the only broader trust opt-in:
# COS_CODEX_SANDBOX=workspace-write

# ── VOICE (optional) ────────────────────────────────────────────────────
# Local transcription is FREE via whisper.cpp (brew install whisper-cpp; the
# model auto-downloads on first run). Voice is local-only by default. Merely
# configuring a key never uploads audio. To allow OpenAI Whisper only after a
# local failure, set BOTH the exact opt-in and a key:
# COS_OPENAI_WHISPER_FALLBACK=1
# OPENAI_API_KEY=sk-...

# ── FULL COS PIPELINE (optional — leave unset for standalone) ────────────
# Power users running the COS Starter Kit can point the glasses at their
# pipeline to inherit live tasks/calendar/people context. Omit for standalone.
# COS_SCRIPTS_DIR=/path/to/your/cos/operations/scripts
